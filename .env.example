# Başak Vardiya — Firebase Web yapılandırması
# Firebase Console > Proje Ayarları > Web App > SDK setup and configuration
# Aşağıdaki değerleri kendi projenizin (basak-app-e7a0c) değerleriyle doldurup
# dosyayı `.env` olarak kaydedin. Vite, VITE_ önekli değişkenleri istemciye gömer.

VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=basak-app-e7a0c.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=basak-app-e7a0c
VITE_FIREBASE_STORAGE_BUCKET=basak-app-e7a0c.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx

# Vardiya verisi bu koleksiyon ad alanı altında tutulur (diğer modüllere dokunmaz).
VITE_VARDIYA_NAMESPACE=vardiya

# Seed script'i için (Node ortamı) — aynı değerleri kullanır.
# Servis hesabı yerine web config + anonim/normal giriş ile çalışır.
